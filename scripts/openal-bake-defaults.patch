+/* Rombadil: seed [general] defaults so the DLL works without a runtime
+ * alsoft.ini / alsoft.conf. Called at the start of ReadALConfig, so any
+ * value loaded from a config file afterwards overrides these.
+ */
+static void SetDefaultConfigEntry(std::string key, std::string value)
+{
+    const auto ent = std::ranges::find(ConfOpts, key, &ConfigEntry::key);
+    if(ent == ConfOpts.end())
+        ConfOpts.emplace_back(std::move(key), std::move(value));
+}
